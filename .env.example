# ============================================================
# PDFlow Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=pdflow
POSTGRES_PASSWORD=pdflow_secret
POSTGRES_DB=pdflow
DATABASE_URL=postgresql://pdflow:pdflow_secret@localhost:5432/pdflow

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery (Python worker) ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT Authentication ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# --- AWS S3 / Object Storage ---
S3_BUCKET=pdflow-uploads
S3_REGION=us-east-1
S3_ENDPOINT=                          # Leave blank for AWS, set for MinIO/R2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=debug                       # debug | info | warning | error

# --- Python API ---
PYTHON_API_PORT=8000

# --- Node API ---
NODE_API_PORT=3001
NODE_ENV=development

# --- Frontend (Next.js) ---
NEXT_PUBLIC_PYTHON_API_URL=http://localhost:8000
NEXT_PUBLIC_NODE_API_URL=http://localhost:3001

# --- Railway (set these in Railway dashboard, not here) ---
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# --- Optional: Sentry Error Tracking ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- Optional: Stripe Billing ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
